  pub struct CanonicalEntity { pub id: String, pub created: bool, pub merged_with: Option<String> }
  pub struct ReconcilerStats { auto_merges, llm_merges, llm_news, auto_news, llm_calls, llm_ms }
  impl EntityReconciler {
