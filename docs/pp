  pub auto_merge_threshold: f32,           // RECONCILER_AUTO_MERGE_THRESHOLD, default 0.92
  pub llm_review_threshold: f32,           // RECONCILER_LLM_REVIEW_THRESHOLD, default 0.75
  pub vector_topk: usize,                  // RECONCILER_VECTOR_TOPK, default 5
