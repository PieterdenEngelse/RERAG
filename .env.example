# Logging presets
# Production
# RUST_LOG=info,tantivy=warn
# Development
# RUST_LOG=debug,tantivy=info

# Metrics histogram buckets (milliseconds)
# SEARCH_HISTO_BUCKETS=1,2,5,10,20,50,100,250,500,1000
# REINDEX_HISTO_BUCKETS=50,100,250,500,1000,2000,5000,10000

# Profiling feature is enabled at compile time:
# cargo run --features profiling

# Chunker configuration
# CHUNKER_MODE=fixed        # Options: fixed, lightweight, semantic
# CHUNKING_SNAPSHOT_LOGGING=true       # Disable with false/0 to stop logging snapshots

# Chunk size configuration (optimized for BGE-small-en-v1.5 embedding model)
# BGE-small has 512 token max sequence length, so chunks should be smaller
# CHUNK_TARGET_SIZE=256     # Target tokens per chunk (default: 256, ~50% of model max)
# CHUNK_MIN_SIZE=128        # Minimum tokens per chunk (default: 128)
# CHUNK_MAX_SIZE=384        # Maximum tokens per chunk (default: 384, leaves room for query)
# CHUNK_OVERLAP=32          # Overlap tokens between chunks (default: 32, ~12%)
# CHUNK_MAX_CHARS=1500      # Max characters for simple chunker (default: 1500)
# SEMANTIC_SIMILARITY_THRESHOLD=0.78    # Threshold for semantic chunking (0.0-1.0)

# Embedding configuration
# EMBEDDING_PROVIDER=fastembed      # Options: fastembed, hash (fallback)
# EMBEDDING_MODEL=bge-small-en-v1.5 # Model name passed to fastembed
# EMBEDDING_BATCH_SIZE=32           # Async embedding batch size
# EMBEDDING_CACHE_SIZE=10000        # LRU cache entries for EmbeddingService
# EMBEDDING_HISTO_BUCKETS=1,5,10,25,50,100,250,500,1000  # Histogram buckets for embedding latency (ms)

# Inference gateway (concurrency control)
# INFERENCE_MAX_CONCURRENT_EMBEDDINGS=4  # Max concurrent embedding operations
# INFERENCE_MAX_CONCURRENT_LLM=2         # Max concurrent LLM inference operations
# INFERENCE_ACQUIRE_TIMEOUT_MS=30000     # Timeout for acquiring a permit (0 = no timeout)

# ─────────────────────────────────────────────────────────────
# Trace-Based Alerting (Tempo Integration)
# ─────────────────────────────────────────────────────────────

# Enable trace-based alerting (queries Tempo for anomalies)
# TEMPO_ENABLED=false

# Tempo API endpoint
# TEMPO_URL=http://127.0.0.1:3200

# Skip TLS verification for Tempo HTTPS endpoint (default: false)
# Set to true when using self-signed certificates in development
# WARNING: Only use in development/testing environments
# TEMPO_ALERT_INSECURE_TLS=false

# Alert check interval in seconds (default: 30)
# Every 30s = 2 queries/min
# TEMPO_ALERT_INTERVAL_SECS=30

# Latency threshold in milliseconds (default: 1000)
# Alert if span duration exceeds this value
# TEMPO_LATENCY_THRESHOLD_MS=1000

# Error rate threshold (0.0-1.0, default: 0.05 = 5%)
# Alert if error rate exceeds this percentage
# TEMPO_ERROR_RATE_THRESHOLD=0.05

# Webhook URL for trace anomaly alerts (optional)
# TEMPO_ALERT_WEBHOOK_URL=https://example.com/alerts/traces

# Lookback window in seconds (default: 60)
# How far back to query for traces
# TEMPO_LOOKBACK_WINDOW_SECS=60

# ─────────────────────────────────────────────────────────────
# Resource Attribution (Tracing Overhead Monitoring)
# ─────────────────────────────────────────────────────────────

# Enable resource attribution tracking (default: true)
# Tracks memory and CPU overhead from distributed tracing
# RESOURCE_ATTRIBUTION_ENABLED=true

# Update interval in seconds (default: 60)
# How often to update resource metrics
# RESOURCE_ATTRIBUTION_UPDATE_INTERVAL_SECS=60
