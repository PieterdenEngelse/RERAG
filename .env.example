# ═══════════════════════════════════════════════════════════════════════════════
# RERAG — Rust Educational RAG · Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed
# Start infrastructure: docker compose -f docker-compose.full.yml up -d

# ───────────────────────────────────────────────────────────────────────────────
# CORE SETTINGS
# ───────────────────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3010

# Upload server runs on a separate port to isolate write traffic from reads.
UPLOAD_HOST=127.0.0.1
UPLOAD_PORT=3011

# Optional: directory of bundled frontend assets the backend serves at /.
# When unset, the backend resolves the dist via this precedence:
#   1. AG_WEB_DIR
#   2. $AG_HOME/web/
#   3. ~/.local/share/ag/web/   (XDG fallback, matches PathManager)
# If none of those contain index.html, "/" responds with a placeholder text
# message and /health, /ready, /api/... continue to work normally. The AppImage
# installer bundles dist into $AG_HOME/web/, so the env var typically isn't
# needed — set it only if you want to serve from a non-standard location.
# AG_WEB_DIR=

RUST_LOG=info

# Skip indexing on startup (useful for faster dev restarts)
SKIP_INITIAL_INDEXING=false

# When true, Tantivy index segments are heap-allocated (RamDirectory) instead of
# memory-mapped from disk. Search latency is lower, but:
#   - All documents are re-indexed on every restart (combine with SKIP_INITIAL_INDEXING=false)
#   - Memory usage scales with corpus size — recommended for <100 docs only
INDEX_IN_RAM=false

# ───────────────────────────────────────────────────────────────────────────────
# CHUNKER
# ───────────────────────────────────────────────────────────────────────────────
# Chunking algorithm applied to every ingested document.
# Options: fixed | lightweight (recommended) | sentence | semantic | pipeline
CHUNKER_MODE=lightweight
CHUNK_TARGET_SIZE=256
CHUNK_MIN_SIZE=128
CHUNK_MAX_SIZE=384
CHUNK_OVERLAP=32
SEMANTIC_SIMILARITY_THRESHOLD=0.75
CHUNK_CLEAN_HTML=false
CHUNK_CLEAN_UNICODE=false
CHUNK_CONTEXT_PREFIX=false
CHUNK_CONTEXT_PREFIX_TOKENS=32
# Only used when CHUNKER_MODE=pipeline. Options: lw,sent | sent,sem | lw,sent,sem
PIPELINE_STAGES=lw,sent,sem

# ───────────────────────────────────────────────────────────────────────────────
# LLM BACKEND (Ollama)
# ───────────────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ───────────────────────────────────────────────────────────────────────────────
# ONNX EMBEDDING MODEL (semantic/pipeline chunking + vector search)
# ───────────────────────────────────────────────────────────────────────────────
# ONNX graph file for the embedding model used by semantic chunking and retrieval.
# Place the model file at ONNX_MODEL_PATH and its tokenizer.json in the same
# directory.  Both can be fetched from the model's HuggingFace page.
#
# Supported values for EMBEDDING_MODEL:
#   bge-small-en-v1.5   — 384 dims, 33 MB   — default, good balance
#   bge-small-en-v1.5q  — 384 dims, ~8 MB   — INT8 quantized, ~30% faster
#   all-minilm-l6-v2    — 384 dims, 22 MB   — faster, comparable quality
#   bge-base-en-v1.5    — 768 dims, 109 MB  — best quality, needs re-index on switch
#   e5-small-v2         — 384 dims, 33 MB   — prefix queries with "query: "
#
# HuggingFace download (example for bge-small-en-v1.5):
#   mkdir -p backend/models
#   wget -O backend/models/embedding_model.onnx \
#        https://huggingface.co/BAAI/bge-small-en-v1.5/resolve/main/onnx/model.onnx
#   wget -O backend/models/tokenizer.json \
#        https://huggingface.co/BAAI/bge-small-en-v1.5/resolve/main/tokenizer.json
#
# WARNING: switching to a model with different dimensions (e.g. bge-base → 768)
# requires deleting and rebuilding the vector index.
EMBEDDING_MODEL=bge-small-en-v1.5
ONNX_MODEL_PATH=models/embedding_model.onnx
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_SIZE=10000

# ───────────────────────────────────────────────────────────────────────────────
# CLOUD LLM API KEYS
# ───────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...   # https://openrouter.ai — unified gateway to 100+ models

# ───────────────────────────────────────────────────────────────────────────────
# REDIS CACHE (L3)
# ───────────────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/
REDIS_TTL=3600

# ───────────────────────────────────────────────────────────────────────────────
# EXTERNAL DOCUMENT EXTRACTORS
# ───────────────────────────────────────────────────────────────────────────────
# Docling sidecar — structural extraction for PDF, DOCX, PPTX, XLSX, EPUB.
# Start with: docker compose --profile docling up -d
DOCLING_ENABLED=false
DOCLING_URL=http://localhost:5001

# Upload size cap — requests over this limit are rejected with 413 before any
# bytes are written to disk. Default: 150 MB.
UPLOAD_MAX_MB=150

# ───────────────────────────────────────────────────────────────────────────────
# DUAL-SERVER TUNING
# Search server (3010): handles reads — search, list, config, memory recall.
# Upload server (3011): handles writes — upload, delete, reindex, store.
# ───────────────────────────────────────────────────────────────────────────────

# Actix worker threads (defaults: search = nCPU-2, upload = 2)
SEARCH_WORKERS=4
UPLOAD_WORKERS=2

# Max simultaneous TCP connections per server
SEARCH_MAX_CONNECTIONS=1000
UPLOAD_MAX_CONNECTIONS=50

# Semaphore: concurrent uploads in flight (returns 503 + Retry-After: 1 when full)
UPLOAD_MAX_CONCURRENT=4

# Max body size for search requests (KB). Keeps search server memory predictable.
SEARCH_MAX_BODY_KB=64

# Request timeouts
SEARCH_TIMEOUT_SECS=30
UPLOAD_TIMEOUT_SECS=300

# ONNX blocking thread pool for the upload server (embedding during ingest)
UPLOAD_ONNX_THREADS=4

# Restrict upload CORS to specific origins (comma-separated). Unset = allow any.
# UPLOAD_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# KNOWLEDGE GRAPH (GraphRAG) — FalkorDB backend
# ───────────────────────────────────────────────────────────────────────────────
# Backed by FalkorDB (a Redis module). See docs/falkordb-migration.md.
FALKOR_ENABLED=true
# Redis-protocol URL. Host port 6380 (docker-compose) keeps it off the L3 cache redis.
FALKOR_URI=redis://localhost:6380
FALKOR_PASSWORD=agpassword123
# Graph key name — the first argument to GRAPH.QUERY.
FALKOR_DATABASE=ag
FALKOR_MAX_CONNECTIONS=10
# Time to *open* a connection before giving up.
FALKOR_CONNECTION_TIMEOUT_MS=5000
# Per-query command timeout — caps how long a FalkorDB query may run, enforced
# server-side. 0 = no timeout.
FALKOR_COMMAND_TIMEOUT_MS=0

# Graph expansion settings
GRAPH_EXPANSION_ENABLED=true
GRAPH_EXPANSION_MAX_HOPS=2
GRAPH_EXPANSION_MAX_CHUNKS=10
GRAPH_ENTITY_WEIGHT=0.7
GRAPH_CONCEPT_WEIGHT=0.5
GRAPH_MIN_RELATIONSHIP_STRENGTH=0.3

# Entity extraction settings
ENTITY_EXTRACTION_ENABLED=true
ENTITY_EXTRACTION_CONFIDENCE_THRESHOLD=0.5
ENTITY_LINKING_FUZZY_THRESHOLD=0.8

# ───────────────────────────────────────────────────────────────────────────────
# OPENTELEMETRY (Distributed Tracing)
# ───────────────────────────────────────────────────────────────────────────────
OTEL_TRACES_ENABLED=true
OTEL_OTLP_EXPORT=true
OTEL_CONSOLE_EXPORT=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ag-backend
OTEL_SERVICE_VERSION=13.1.2
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_INSECURE=true

# ───────────────────────────────────────────────────────────────────────────────
# TEMPO (Trace Storage & Alerting)
# ───────────────────────────────────────────────────────────────────────────────
TEMPO_ENABLED=true
TEMPO_URL=http://localhost:3200
TEMPO_ALERT_INTERVAL_SECS=30
TEMPO_LATENCY_THRESHOLD_MS=1000
TEMPO_ERROR_RATE_THRESHOLD=0.05
TEMPO_LOOKBACK_WINDOW_SECS=60

# ───────────────────────────────────────────────────────────────────────────────
# TRAINING DATA COLLECTION
# ───────────────────────────────────────────────────────────────────────────────
TRAINING_DATA_ENABLED=true
TRAINING_MIN_QUALITY=3

# ───────────────────────────────────────────────────────────────────────────────
# IO_URING (Linux 5.1+ only, optional)
# ───────────────────────────────────────────────────────────────────────────────
#IO_URING_RING_SIZE=256
#IO_URING_BUFFER_SIZE=65536
#IO_URING_SQPOLL=false
#IO_URING_SQPOLL_IDLE_MS=1000
#IO_URING_BUFFER_POOL_SIZE=64
#IO_URING_SINGLE_ISSUER=true
